{
  "name": "PDF Text to Speech",
  "description": "Read PDF documents aloud directly in the browser.",
  "version": "1.0.0",
  "manifest_version": 3,
  "action": {
    "default_title": "PDF Text to Speech",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.svg",
      "32": "icons/icon-32.svg",
      "48": "icons/icon-48.svg",
      "128": "icons/icon-128.svg"
    }
  },
  "permissions": ["activeTab", "scripting"],
  "host_permissions": [
    "*://*/*.pdf",
    "*://*/*.PDF",
    "file:///*.pdf",
    "file:///*.PDF",
    "http://localhost:8787/*",
    "https://your-tts-proxy.example.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*/*.pdf",
        "*://*/*.PDF",
        "file:///*.pdf",
        "file:///*.PDF"
      ],
      "js": ["config.js", "contentScript.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon-16.svg",
    "32": "icons/icon-32.svg",
    "48": "icons/icon-48.svg",
    "128": "icons/icon-128.svg"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "node_modules/pdfjs-dist/legacy/build/pdf.min.mjs",
        "node_modules/pdfjs-dist/legacy/build/pdf.worker.min.mjs"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
